# vim: filetype=zsh
# Compara la interpolación de colores en RGB, HSL, Lab y OkLab.
# Permite visualizar cómo cada espacio de color genera transiciones
# diferentes entre los mismos colores de origen y destino.

local color1="$1"
local color2="$2"
local steps="${3:-20}"

local spaces=(
    RGB
    HSL
    Lab
    OkLab
)

# Genera cuatro gradientes entre los mismos colores de origen y destino,
# variando únicamente el espacio de interpolación (RGB, HSL, Lab y OkLab).
#
# pastel gradient devuelve una lista de colores, uno por línea. La salida
# se normaliza a formato hexadecimal mediante 'pastel format hex' para que
# todos los espacios puedan compararse con la misma representación.
#
# La expansión zsh '${(@f)...}' divide la cadena multilínea en un array,
# usando cada salto de línea como separador. Así, cada posición del array
# representa el mismo paso dentro del gradiente.
#
# Ejemplo:
#
#   rgb_gradient[1]   → primer color RGB
#   hsl_gradient[1]   → primer color HSL
#   lab_gradient[1]   → primer color Lab
#   oklab_gradient[1] → primer color OkLab
#
# Esto permite comparar visualmente el paso N de cada espacio de color
# imprimiendo los cuatro colores en una misma fila.

for space in "${spaces[@]}"; do
    gradient=$(
        pastel gradient \
            --colorspace "$space" \
            "$color1" \
            "$color2" \
            --number "$steps" \
            | pastel format hex
    )

    case "$space" in
        RGB) rgb_gradient=("${(@f)gradient}") ;;
        HSL) hsl_gradient=("${(@f)gradient}") ;;
        Lab) lab_gradient=("${(@f)gradient}") ;;
        OkLab) oklab_gradient=("${(@f)gradient}") ;;
    esac

done

# Impresión de múltiples segmentos coloreados en una misma línea.
#
# pastel paint agrega un salto de línea al finalizar. La opción '-n'
# (no newline) evita ese comportamiento y permite encadenar múltiples
# bloques coloreados en una única fila.
#
# Ejemplo:
#
#   pastel paint -n yellow "YELLOW"
#   echo -n " message without color"
#   echo -n " RED" | pastel paint -n red
#   echo " GREEN" | pastel paint -n green
#
# Resultado:
#
#   YELLOW message without color RED GREEN
#
# Esto permite construir tablas y comparadores visuales de colores
# imprimiendo varios bloques consecutivos y emitiendo un único salto
# de línea al final de cada fila.

for ((i = 1; i <= ${#rgb_gradient[@]}; i++)); do
    pastel paint -n "${hsl_gradient[i]}" "🮍███🮌 HSL ${hsl_gradient[i]} "
    pastel paint -n "${rgb_gradient[i]}" "🮍███🮌 RGB ${rgb_gradient[i]} "
    pastel paint -n "${lab_gradient[i]}" "🮍███🮌 Lab ${lab_gradient[i]} "
    pastel paint -n "${oklab_gradient[i]}" "🮍███🮌 OkLab ${oklab_gradient[i]} "
    echo # <- único responsable del salto de línea en este ciclo.
done
