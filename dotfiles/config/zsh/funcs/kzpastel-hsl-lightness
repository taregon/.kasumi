# vim: filetype=zsh
# Genera una escala tonal en el espacio HSL modificando únicamente la
# luminosidad (lightness). El matiz y la saturación del color base se
# mantienen constantes en HSL.
#
# HSL-lightness es una transformación geométrica sobre RGB y no un modelo
# perceptualmente uniforme. Por ello, incrementos iguales de lightness no
# necesariamente producen incrementos visuales iguales de claridad.
#
# Dependiendo del color base, la escala resultante puede mantener una buena
# estabilidad de matiz y croma, aunque el comportamiento perceptual suele
# ser menos uniforme que al ajustar la componente L de OkLab.
#
# Uso: kzpastel-hsl-lightness <color> <pasos> [min] [max]
#   min — luminosidad mínima (0–100, default 10)
#   max — luminosidad máxima (0–100, default 96)

local base="$1"
local steps="$2"
local light_min="${3:-10}"
local light_max="${4:-96}"

[[ -z "$base" || -z "$steps" ]] && {
    echo "Uso: kzpastel-hsl-lightness <color> <pasos> [min] [max]"
    return 1
}

((steps > 1)) || {
    echo "Se requieren al menos 2 pasos"
    return 1
}

for ((i = 0; i < steps; i++)); do
    light_level=$(bc -l <<< \
        "scale=4; ($light_min + $i * ($light_max - $light_min) / ($steps - 1)) / 100")

    hex_color=$(
        pastel set hsl-lightness "$light_level" "$base" \
            | pastel format oklch
    )

    hex_c=$(
        pastel format hex "$hex_color"
    )

    pastel paint "$hex_color" \
        "▋    HSL Lightness ${hex_color}  ── $hex_c ──  🮍███🮌"
done
