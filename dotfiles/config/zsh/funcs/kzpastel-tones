# vim: filetype=zsh
# Genera una escala tonal a partir de un color base utilizando las
# transformaciones perceptuales disponibles en Pastel.
#
# Modos disponibles:
#   l : ajusta la propiedad 'lightness' (escala tonal tradicional)
#   o : ajusta la componente L de OkLab (escala tonal perceptual, default)
#   h : ajusta la luminosidad en espacio HSL
#
# La luminosidad se interpola linealmente entre valores mínimos y máximos
# definidos para cada modo, produciendo transiciones progresivas entre
# tonos oscuros y claros del mismo color base.
#
# Uso: kzpastel-tones <color> <min> <max> <pasos> [modo]
#   modo — l | o | h (default: o)
#
# El resultado se convierte a hexadecimal y se muestra como una muestra
# coloreada directamente en la terminal.

local base="$1"
local light_min="${2:-30}"
local light_max="${3:-96}"
local steps="${4:-20}"
local mode="${5:-o}"

[[ -z "$base" || -z "$steps" ]] && {
    echo "Uso: kzpastel-tones <color> <min> <max> <pasos> [modo]"
    return 1
}

((steps > 1)) || {
    echo "Se requieren al menos 2 pasos"
    return 1
}

((light_min >= 0 && light_max <= 100)) || {
    echo "min y max deben estar entre 0 y 100"
    return 1
}

# Generar cada color de la escala.
for ((i = 0; i < steps; i++)); do
    case "$mode" in

        l)
            # Interpolación utilizando la propiedad genérica 'lightness'
            # expuesta por Pastel. Esta propiedad produce resultados distintos
            # a la componente L de Oklab.
            light_level=$(bc -l <<< \
                "scale=4; $light_min + $i * ($light_max - $light_min) / ($steps - 1)")

            light_pct=$(printf "%4.1f" "$light_level")

            property="lightness"
            label="Light"
            ;;

        o)
            # Interpolación utilizando la componente L de Oklab.
            # Oklab emplea una escala normalizada, por lo que el nivel de
            # luminosidad se convierte posteriormente de porcentaje (0–100)
            # a un valor decimal (0.0–1.0).
            light_level=$(bc -l <<< \
                "scale=4; ($light_min + $i * ($light_max - $light_min) / ($steps - 1)) / 100")

            light_pct=$(printf "%4.1f" "$(bc -l <<< "$light_level * 100")")

            property="oklab-l"
            label="Oklab"
            ;;

        h)
            # HSL-lightness es una transformación geométrica sobre RGB,
            # no un modelo perceptual. Incrementos iguales de lightness
            # no producen saltos visuales uniformes de claridad.
            light_level=$(bc -l <<< \
                "scale=4; ($light_min + $i * ($light_max - $light_min) / ($steps - 1)) / 100")

            light_pct=$(printf "%4.1f" "$(bc -l <<< "$light_level * 100")")

            property="hsl-lightness"
            label="HSL L"
            ;;

        *)
            echo "Modo inválido: $mode"
            return 1
            ;;
    esac

    # Aplicar el nivel de luminosidad calculado al color base y
    # convertir el resultado a formato hexadecimal.
    hex_color=$(
        pastel set "$property" "$light_level" "$base" \
            | pastel format hex
    )

    # Mostrar una muestra visual junto con el valor hexadecimal generado.
    pastel paint "$hex_color" \
        "▋     Lorem ipsum dolor sit amet  │ $label ├── $hex_color ── $light_pct% ──┤  🮍███🮌"

done
