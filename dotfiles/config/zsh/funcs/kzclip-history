#!/usr/bin/env zsh
# Muestra el historial del portapapeles con fzf, incluyendo
# vista previa para texto e imágenes, y copia la selección
# nuevamente al portapapeles usando wl-copy.

local preview_cmd='
entry={}
printf "\033[2J\033[H"

if [[ "$entry" == *"[[ binary data"* ]]; then
  printf "%s\n" "$entry" | cliphist decode 2>/dev/null |
    kitten icat --clear \
      --transfer-mode=memory \
      --unicode-placeholder \
      --stdin=yes \
      --place="$((FZF_PREVIEW_COLUMNS - 2))x${FZF_PREVIEW_LINES}@0x0"
else
  printf "%s\n" "$entry" | cliphist decode 2>/dev/null
fi
'

# --bind: Vincula la tecla Supr para eliminar la entrada seleccionada
# de cliphist y recargar la lista sin cerrar fzf
local selected=$(
    cliphist list | fzf \
        --tiebreak=index \
        --preview "$preview_cmd" \
        --preview-window 'right:50%:wrap' \
        --layout reverse \
        --border \
        --bind 'delete:execute-silent(echo {} | cliphist delete)+reload(cliphist list)' \
        --header $'  Buscar en portapapeles\n<Supr> eliminar entrada  <Enter> copiar'
)

# Decodifica la entrada seleccionada y ejecuta wl-copy en segundo plano
# para evitar bloqueos o retención de la terminal al finalizar el script
# Anteriormente: [[ -n "$selected" ]] && echo "$selected" | cliphist decode | wl-copy
[[ -n "$selected" ]] && cliphist decode <<< "$selected" | wl-copy > /dev/null 2>&1 &
