# vim: filetype=zsh
# Descarga y corta audio de videos de YouTube
#
# Uso: kzaudio-cut <url> <inicio> <fin> [archivo_salida]
# Ejemplo: kzaudio-cut "https://youtube.com/watch?v=ID" 00:48:20 00:51:13 mi_clip.m4a
#
# Descarga el mejor audio disponible (ordenado por códec opus y bitrate),
# lo corta con ffmpeg usando seek preciso, y lo guarda en M4A/AAC.
# Si el archivo de salida ya existe, se salta la descarga.

local url="$1"
local start="$2"
local end="$3"
local outfile

if [[ -z "$url" || -z "$start" || -z "$end" ]]; then
    echo "Uso: kzaudio-cut <url> <inicio> <fin> [archivo_salida]"
    return 1
fi

if [[ -z "$4" ]]; then
    local title
    title=$(yt-dlp --print "%(title)s" -s "$url" 2>/dev/null)
    title=${title//[^a-zA-Z0-9_-]/}
    title=${title:0:40}
    outfile="yt_audiocut-${title}-${start//:/-}-${end//:/-}.m4a"
else
    outfile="$4"
fi

if [[ -s "$outfile" ]]; then
    echo "  El archivo ya existe: $outfile"
    return 0
fi

# Archivo temporal para descargar el mejor audio
local tmpfile="/tmp/kzaud-$RANDOM-$(date +%s).tmp"

trap 'rm -f "$tmpfile"' EXIT INT TERM

echo "[1/2] Descargando mejor audio disponible (ordenado por calidad)..."
yt-dlp -f bestaudio --format-sort "acodec:opus,abr" --force-overwrites -o "$tmpfile" "$url" || {
    echo "  No se pudo descargar el audio. "
    echo "   Revisa el URL o formatos disponibles con 'yt-dlp -F $url'"
    return 1
}

if [[ ! -s "$tmpfile" ]]; then
    echo "  Archivo descargado vacío"
    return 1
fi

echo "[2/2] Cortando audio (preservando calidad)..."
ffmpeg -hide_banner -loglevel info \
    -i "$tmpfile" \
    -ss "$start" -to "$end" \
    -c:a aac -q:a 0 \
    "$outfile" || {
    echo "  ffmpeg falló durante el corte/recodificación"
    return 1
}

if [[ -s "$outfile" ]]; then
    echo "  Clip generado: $outfile"
else
    echo "  No se generó el archivo de salida"
    return 1
fi
