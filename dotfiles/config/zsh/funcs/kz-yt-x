# vim: filetype=zsh
# yt-dlp para X/Twitter con cookies del navegador.
# Soporta tweets privados extrayendo cookies de Firefox.
# Prioriza MP4 + M4A con thumbnail y metadata embebida.
#
# Uso: kz-yt-x <url>

# Navegador: firefox, chrome, chromium, brave, edge, opera, vivaldi, whale
local browser="firefox"

yt-dlp \
    --cookies-from-browser "$browser" \
    --embed-metadata \
    --embed-thumbnail \
    --windows-filenames \
    --trim-filenames 70 \
    --write-desktop-link \
    --xff default \
    -f "bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best" \
    -o "%(webpage_url_domain)s [%(id)s] %(uploader)s - %(title)s.%(ext)s" \
    "$@"
