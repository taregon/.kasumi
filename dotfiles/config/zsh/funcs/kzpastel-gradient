# vim: filetype=zsh
# Genera gradientes de color entre dos o tres colores mediante interpolación en el espacio OkLab.
# Produce transiciones suaves y visualmente equilibradas, útiles para paletas, temas de terminal e interfaces.

local steps="$1"
local color1="$2"
local color2="$3"
local color3="$4"

if [[ -z "$steps" || -z "$color1" || -z "$color2" ]]; then
    echo "Uso: gradient <pasos> <color1> <color2> [color3]"
    return 1
fi

if [[ -n "$color3" ]]; then
    pastel gradient \
        --number "$steps" \
        --colorspace OkLab \
        "$color1" \
        "$color2" \
        "$color3" \
        | pastel format hex
else
    pastel gradient \
        --number "$steps" \
        --colorspace OkLab \
        "$color1" \
        "$color2" \
        | pastel format hex
fi
