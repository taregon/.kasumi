# vim: filetype=zsh

# Lista ventanas/contenedores reales de Sway y muestra:
# título, app_id Wayland, clase X11, estado de foco y urgencia

swaymsg -t get_tree | jq '
.. | objects
| select(.type=="con" and (.app_id? or .window?))
| {
    name,
    app_id,
    class:(.window_properties?.class),
    focused,
    urgent
  }'
