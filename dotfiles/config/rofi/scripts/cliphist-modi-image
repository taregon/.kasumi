#!/usr/bin/env bash

# Muestra las últimas 12 entradas con datos binarios (imágenes),
# generando thumbnails en /tmp. Enter copia al portapapeles (wl-copy),
# Alt+Delete elimina la entrada del historial.

# Pruebas:  rofi -show cliphist -kb-custom-1 "Alt+Delete" \
#               -modi "cliphist:~/.config/rofi/scripts/cliphist-modi-text" \

set -euo pipefail

tmp_dir=$(mktemp -d)

# Genera thumbnails y los lista para rofi
list_images() {
    cliphist list \
        | grep -F '[[ binary data' \
        | head -n 12 \
        | while IFS= read -r entry; do
            id="${entry%% *}"
            img="$tmp_dir/$id"
            if [[ ! -f "$img" ]]; then
                cliphist decode <<< "$entry" > "$img"
            fi
            printf '%s\0icon\x1f%s\n' "$entry" "$img"
        done
}

# ── 1. LISTADO (UI) ─────────────────────────────────────────
if [[ "${ROFI_RETV:-0}" -eq 0 ]]; then
    echo -en "\0use-hot-keys\x1ftrue\n"
    list_images
    exit 0
fi

# ── 2. SELECCIÓN ────────────────────────────────────────────
selection="${1:-}"
[[ -n "$selection" ]] || exit 0

# ── 3. DELETE (Alt+Delete) ──────────────────────────────────
if [[ "${ROFI_RETV:-0}" -eq 10 ]]; then
    cliphist delete <<< "$selection"
    notify-send "Cliphist" "Entrada eliminada" -t 1200
    echo -en "\0use-hot-keys\x1ftrue\n\0keep-selection\x1ftrue\n"
    list_images
    exit 0
fi

# ── 4. COPY (Enter) ─────────────────────────────────────────
cliphist decode <<< "$selection" | wl-copy
notify-send "Cliphist" "Contenido copiado al portapapeles" -t 1200
