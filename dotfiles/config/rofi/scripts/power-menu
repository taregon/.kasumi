#!/usr/bin/env bash
#
# MenГє de acciones de sistema (lock, logout, suspend, hibernate, reboot,
# shutdown) lanzado vГ­a rofi dmenu. Confirma acciones destructivas antes de
# ejecutarlas.

set -euo pipefail

# в”Ђв”Ђ Constantes в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

# Rutas de temas de rofi
readonly rofi_theme_powermenu="$HOME/.config/rofi/themes/powermenu.rasi"
readonly rofi_theme_confirm="$HOME/.config/rofi/themes/confirm.rasi"

# Texto del mensaje principal
host="$(cat /proc/sys/kernel/hostname 2> /dev/null || echo "sway")"
readonly rofi_prompt="${host} (sway)"
uptime_msg="Uptime : $(uptime -p | sed -e 's/up //g')"
readonly uptime_msg

# Opciones del menГє de acciones
readonly opt_lock="пЂЈ  Lock"
readonly opt_logout="п‹µ  Logout"
readonly opt_suspend="п††  Suspend"
readonly opt_hibernate="п€¶  Hibernate"
readonly opt_reboot="п‹№  Reboot"
readonly opt_shutdown="вЏ»  Shutdown"

# Opciones de confirmaciГіn
readonly confirm_yes='пЂЊ  Yes'
readonly confirm_no='пЂЌ  No'

# в”Ђв”Ђ Capa de presentaciГіn (rofi) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

menu_show() {
    rofi -dmenu \
        -p "$rofi_prompt" \
        -mesg "$uptime_msg" \
        -markup-rows \
        -theme "${rofi_theme_powermenu}"
}

confirm_show() {
    rofi -dmenu \
        -p 'Confirmation' \
        -mesg 'Are you Sure?' \
        -theme "${rofi_theme_confirm}"
}

# в”Ђв”Ђ Capa de interacciГіn в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

confirm_prompt() {
    echo -e "$confirm_yes\n$confirm_no" | confirm_show
}

# Lee la selecciГіn del usuario y ejecuta el comando si confirma
confirm_exec() {
    selected="$(confirm_prompt)"
    if [[ "$selected" == "$confirm_yes" ]]; then
        "$@" && exit 0
    else
        exit 1
    fi
}

# Las opciones se pasan como lГ­neas a menu_show; el orden coincide con cmd_dispatch
menu_prompt() {
    echo -e "$opt_lock\n$opt_logout\n$opt_suspend\n$opt_hibernate\n$opt_reboot\n$opt_shutdown" | menu_show
}

# в”Ђв”Ђ Capa de acciones в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

cmd_dispatch() {
    case "$1" in
        --lock)
            "$HOME/.config/sway/scripts/sway-idle" lock
            ;;
        --logout)
            confirm_exec swaymsg exit
            ;;
        --suspend)
            confirm_exec systemctl suspend
            ;;
        --hibernate)
            confirm_exec systemctl hibernate
            ;;
        --reboot)
            confirm_exec systemctl reboot
            ;;
        --shutdown)
            confirm_exec systemctl poweroff
            ;;
    esac
}

# в”Ђв”Ђ Punto de entrada в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

chosen_option="$(menu_prompt)"
case "${chosen_option}" in
    "$opt_lock")
        cmd_dispatch --lock
        ;;
    "$opt_logout")
        cmd_dispatch --logout
        ;;
    "$opt_suspend")
        cmd_dispatch --suspend
        ;;
    "$opt_hibernate")
        cmd_dispatch --hibernate
        ;;
    "$opt_reboot")
        cmd_dispatch --reboot
        ;;
    "$opt_shutdown")
        cmd_dispatch --shutdown
        ;;
esac
