#!/usr/bin/env bash
# Se lanza así:
# rofi \
#     -show cliphist \
#     -modi "cliphist:~/.config/rofi/scripts/cliphist.sh" \
#     -kb-custom-1 "Alt+Delete"

set -euo pipefail

# --------------------------------------------------
# Lista entradas de texto para rofi
# --------------------------------------------------
list_text() {
    cliphist list | grep -Fv '[[ binary data'
}

# -------------------------
# 1. LISTADO (UI)
# -------------------------
if [[ "$ROFI_RETV" -eq 0 ]]; then
    echo -en "\0use-hot-keys\x1ftrue\n"
    list_text
    exit 0
fi

# -------------------------
# 2. DELETE (Alt+Delete)
# -------------------------
if [[ "$ROFI_RETV" -eq 10 ]]; then
    cliphist delete <<< "$1"
    echo -en "\0use-hot-keys\x1ftrue\n\0keep-selection\x1ftrue\n"
    list_text
    exit 0
fi

# -------------------------
# 3. COPY (Enter)
# -------------------------
cliphist decode <<< "$1" | wl-copy
notify-send "Cliphist" "Contenido copiado al portapapeles" -t 1200
