#![enable(implicit_some)]
#![enable(unwrap_newtypes)]
#![enable(unwrap_variant_newtypes)]
(
    // -- Global appearance ------------------------------------------------
    background_color:             "#2E383D",
    text_color:                   "#C0CDD3",
    borders_style:                (fg: "#49575E"),
    highlight_border_style:       (fg: "#A7D6FA"),
    modal_background_color:       None,
    modal_backdrop:               false,

    // -- Item styles -------------------------------------------------------
    current_item_style:           (fg: "#2E383D", bg: "#A7D6FA", modifiers: "Bold"),
    highlighted_item_style:       (fg: "#FF9DCD"),
    preview_label_style:          (fg: "#8598B2"),
    preview_metadata_group_style: (fg: "#8598B2", modifiers: "Bold"),

    // -- Misc config -------------------------------------------------------
    default_album_art_path:       None,
    format_tag_separator:         " | ",
    browser_column_widths:        [20, 38, 42],
    header_background_color:      None,

    // -- Widgets -----------------------------------------------------------
    symbols: (
        song:                       "S",
        dir:                        " ",
        playlist:                   "󰲸 ",
        marker:                     "󰘍 ",
        ellipsis:                   "...",
        dir_current_style:          None,
        dir_highlighted_style:      None,
        dir_style:                  None,
        marker_current_style:       None,
        marker_highlighted_style:   None,
        marker_style:               None,
        playlist_current_style:     None,
        playlist_highlighted_style: None,
        playlist_style:             None,
        song_current_style:         None,
        song_highlighted_style:     None,
        song_style:                 None,
    ),
    level_styles: (
        info:  (fg: "#9EB7C6", bg: "#2E383D"),
        warn:  (fg: "#F8E084", bg: "#2E383D"),
        error: (fg: "#F86E88", bg: "#2E383D"),
        debug: (fg: "#80C8A1", bg: "#2E383D"),
        trace: (fg: "#FF9DCD", bg: "#2E383D"),
    ),
    progress_bar: (
        symbols: ["█", "█", "🮍", "▒", "▒"],
        track_style:   (fg: "#4A585F"),
        elapsed_style: (fg: "#A7D6FA"),
        thumb_style:   (fg: "#A7D6FA", bg: "#4A585F"),
    ),
    scrollbar: (
        symbols: ["│", "█", "⊤", "⊥"],
        track_style: (),
        ends_style:  (),
        thumb_style: (fg: "#5D6C74"),
    ),
    tab_bar: (
        active_style:   (fg: "#2E383D", bg: "#A7D6FA", modifiers: "Bold"),
        inactive_style: (),
    ),
    lyrics: (
        timestamp: false
    ),

    // -- Song list & browser formats --------------------------------------
    browser_song_format: [
        (
            kind: Group([
                (kind: Property(Track)),
                (kind: Text(" ")),
            ])
        ),
        (
            kind: Group([
                (kind: Property(Artist)),
                (kind: Text(" - ")),
                (kind: Property(Title)),
            ]),
            default: (kind: Property(Filename))
        ),
    ],
    song_table_format: [
        (
            prop: (kind: Property(Artist),
                default: (kind: Text("Unknown"))
            ),
            width: "20%",
        ),
        (
            prop: (kind: Property(Title),
                default: (kind: Text("Unknown"))
            ),
            width: "35%",
        ),
        (
            prop: (kind: Property(Album), style: (fg: "#8598B2"),
                default: (kind: Text("Unknown Album"), style: (fg: "#8598B2"))
            ),
            width: "30%",
        ),
        (
            prop: (kind: Property(Duration),
                default: (kind: Text("-"))
            ),
            width: "15%",
            alignment: Right,
        ),
    ],

    // -- Cava visualiser ---------------------------------------------------
    cava: (
        bar_symbols: ['▁', '▂', '▃', '▄', '▅', '▆', '▇', '█'],
        bar_width: 2,
        bar_spacing: 1,
        bar_color: Gradient({
              0: "#414E55",
             50: "#8598B2",
            100: "#A7D6FA",
        })
    ),

    // -- Header rows & layout ---------------------------------------------
    header: (
        rows: [
            (
                left: [
                    (kind: Text("|"), style: (fg: "#5D6C74", modifiers: "Bold")),
                    (kind: Property(Status(StateV2(playing_label: "Playing", paused_label: "Paused", stopped_label: "Stopped"))), style: (fg: "#A7D6FA", modifiers: "Bold")),
                    (kind: Text("|"), style: (fg: "#5D6C74", modifiers: "Bold")),
                ],
                center: [
                    (kind: Property(Song(Title)), style: (modifiers: "Bold"),
                        default: (kind: Text("No Song"), style: (modifiers: "Bold"))),
                ],
                right: [
                    (kind: Property(Widget(ScanStatus)), style: (fg: "#80C8A1")),
                    (kind: Property(Widget(Volume)), style: (fg: "#80C8A1")),
                ],
            ),
            (
                left: [
                    (kind: Property(Status(Elapsed))),
                    (kind: Text(" / ")),
                    (kind: Property(Status(Duration))),
                ],
                center: [
                    (kind: Property(Song(Artist)), style: (fg: "#FFCF94", modifiers: "Bold"),
                        default: (kind: Text("Unknown"), style: (fg: "#FFCF94", modifiers: "Bold"))),
                    (kind: Text(" - "), style: (fg: "#5D6C74")),
                    (kind: Property(Song(Album)), style: (fg: "#C0CDD3"),
                        default: (kind: Text("Unknown Album"), style: (fg: "#C0CDD3"))),
                ],
                right: [
                    (kind: Property(Widget(States(
                        active_style: (fg: "#FF9DCD", modifiers: "Bold"),
                        separator_style: (fg: "#5D6C74"),
                    ))), style: (fg: "#8598B2")),
                ],
            ),
        ],
    ),
    layout: Split(
        direction: Vertical,
        panes: [
            (
                size: "4",
                borders: "ALL",
                pane: Pane(Header),
            ),
            (
                size: "3",
                pane: Pane(Tabs),
            ),
            (
                size: "100%",
                borders: "ALL",
                pane: Pane(TabContent),
            ),
            (
                size: "20%",
                borders: "ALL",
                pane: Pane(Cava),
            ),
            (
                size: "3",
                borders: "ALL",
                pane: Pane(ProgressBar),
            ),
        ],
    ),
)
