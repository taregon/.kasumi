#![enable(implicit_some)]
#![enable(unwrap_newtypes)]
#![enable(unwrap_variant_newtypes)]
(
    // ── Global appearance ──────────────────────────────────────────────
    background_color:             "#2E383D",
    text_color:                   "#C0CDD3",
    borders_style:                (fg: "#667688"),
    highlight_border_style:       (fg: "#A7D6FA"),
    modal_background_color:       None,
    modal_backdrop:               false,

    // ── Item styles ────────────────────────────────────────────────────
    current_item_style:           (fg: "#2E383D", bg: "#A7D6FA", modifiers: "Bold"),
    highlighted_item_style:       (fg: "#FF9DCD"),
    preview_label_style:          (fg: "#667688"),
    preview_metadata_group_style: (fg: "#a16f8c", modifiers: "Bold"),

    // ── Misc config ────────────────────────────────────────────────────
    default_album_art_path:       None,
    format_tag_separator:         " | ",
    browser_column_widths:        [20, 38, 42],
    header_background_color:      None,

    // ── Widgets ────────────────────────────────────────────────────────
    symbols: (
        song:                       "󰽴",
        dir:                        "󰉖 ",
        playlist:                   "󰲹 ",
        marker:                     "🮌",
        ellipsis:                   "...",
        dir_current_style:          None,
        dir_highlighted_style:      None,
        dir_style:                  (fg: "#8598B2"),
        marker_current_style:       None,
        marker_highlighted_style:   None,
        marker_style:               None,
        playlist_current_style:     None,
        playlist_highlighted_style: None,
        playlist_style:             (fg: "#8598B2"),
        song_current_style:         None,
        song_highlighted_style:     None,
        song_style:                 (fg: "#8598B2"),
    ),
    level_styles: (
        info:  (fg: "#9EB7C6", bg: "#2E383D"),
        warn:  (fg: "#F8E084", bg: "#2E383D"),
        error: (fg: "#F86E88", bg: "#2E383D"),
        debug: (fg: "#80C8A1", bg: "#2E383D"),
        trace: (fg: "#FFCF94", bg: "#2E383D"),
    ),
    progress_bar: (
        symbols: ["🯎", "█", "🮉", "░", ""],
        // symbols: ["┥", "▓", "🮋", "░", "█"],
        // symbols: ["▌", "█" , "🭬", "▒", "▒"],
        // symbols: ["█", "█", "🮍", "▒", "▒"],
        // symbols: ["", "", "█", "▒", ""],
        // symbols: ["🭨", "█", "🭬", "▒", "🭬"],
        // symbols: ["𜰯", "𜰯", "𜰯", "𜰯", "𜰯"],

        track_style:   (fg: "#495d68"),
        elapsed_style: (fg: "#A7D6FA"),
        thumb_style:   (fg: "#A7D6FA"),
    ),
    scrollbar: (
        symbols: ["┊", "█", "┯", "┷"],
        track_style: (fg: "#A7D6FA"),
        ends_style:  (fg: "#A7D6FA"),
        thumb_style: (fg: "#667688"),
    ),
    tab_bar: (
        active_style:   (fg: "#2E383D", bg: "#A7D6FA", modifiers: "Bold"),
        inactive_style: (),
    ),
    lyrics: (
        timestamp: false
    ),

    // ── Song list & browser formats ────────────────────────────────────
    browser_song_format: [
        (
            kind: Group([
                (kind: Property(Track)),
                (kind: Text(" ")),
            ])
        ),
        (
            kind: Group([
                (kind: Property(Artist)),
                (kind: Text(" - ")),
                (kind: Property(Title)),
            ]),
            default: (kind: Property(Filename))
        ),
    ],
    song_table_format: [
        (
            prop: (kind: Property(Artist), style: (fg: "#C0CDD3"),
                default: (kind: Text("Unknown"), style: (fg: "#C0CDD3"))
            ),
            width: "20%",
            label: "Artist",
        ),
        (
            prop: (kind: Property(Title), style: (fg: "#a16f8c"),
                default: (kind: Text("Unknown"), style: (fg: "#a16f8c"))
            ),
            width: "35%",
            label: "Title",
        ),
        (
            prop: (kind: Property(Album), style: (fg: "#8598B2"),
                default: (kind: Text("Unknown Album"), style: (fg: "#8598B2"))
            ),
            width: "19%",
            label: "Album",
        ),
        (
            prop: (kind: Property(Duration), style: (fg: "#667688"),
                default: (kind: Text("-"), style: (fg: "#667688"))
            ),
            width: "10%",
            label: "Time",
            alignment: Left,
        ),
        (
            prop: (kind: Transform(Replace(
                content: (kind: Sticker("rating")),
                replacements: [
                    (match: "0", replace: (kind: Text("﹍✕ ﹍"), style: (fg: "#667688"))),
                    (match: "1", replace: (kind: Text(" "), style: (fg: "#8d9ba8"))),
                    (match: "2", replace: (kind: Text("  "), style: (fg: "#C0CDD3"))),
                    (match: "3", replace: (kind: Text("   "), style: (fg: "#A7D6FA"))),
                ],
            )), style: (fg: "#C0CDD3"),
                default: (kind: Text("﹍﹍﹍"), style: (fg: "#4e4e4a"))
            ),
            width: "10%",
            label: "Rate",
            alignment: Left,
        ),
        (
            prop: (kind: Transform(Replace(
                content: (kind: Sticker("like")),
                replacements: [
                    (match: "0", replace: (kind: Text("✕ "), style: (fg: "#4e4e4a"))),
                    (match: "1", replace: (kind: Text("󰻃 "), style: (fg: "#c2a27b"))),
                    (match: "2", replace: (kind: Text("󰫥 "), style: (fg: "#FFCF94"))),
                ],
            )), style: (fg: "#FFCF94"),
                default: (kind: Text("﹍"), style: (fg: "#4e4e4a"))
            ),
            width: "6%",
            label: "Love",
            alignment: Center,
        ),
    ],

    // ── Cava visualiser ────────────────────────────────────────────────
    cava: (
        // bar_symbols: ['▁', '▂', '▃', '▄', '▅', '▆', '▒', '▒'],
        bar_symbols: ['𜺀',  '𜺌', '𜺏' ],
        // bar_symbols: ['𜺀', '𜰬', '𜺌', '𜰯'],
        inverted_bar_symbols: ['▔', '🮂', '🮃', '▀', '🮄', '🮅', '🮆', '█'],
        bar_width: 2,
        bar_spacing: 1,
        // Possible values are "Top", "Bottom" and "Horizontal".
        orientation: Bottom,
        bar_color: Gradient({
                 5: "#495d68",
                35: "#84abc5",
                55: "#a3d1f3",
                75: "#a7d6fa",
                90: "#FF9DCD",
        })
    ),

    // ── Header rows & layout ───────────────────────────────────────────
    header: (
        rows: [
            (
                left: [
                    (kind: Property(Song(SampleRate())), style: (fg: "#667688"),
                        default: (kind: Text("---"), style: (fg: "#667688"))),
                    (kind: Text(" Hz   "), style: (fg: "#667688")),
                    (kind: Property(Status(Bitrate)), style: (fg: "#667688"),
                        default: (kind: Text("---"), style: (fg: "#667688"))),
                    (kind: Text(" kbps"), style: (fg: "#667688")),
                ],
                center: [
                    (kind: Property(Song(Title)), style: (fg: "#FF9DCD", modifiers: "Bold"),
                        default: (kind: Text("No Song"), style: (fg: "#FF9DCD", modifiers: "Bold"))),
                ],
                right: [
                    (kind: Property(Widget(ScanStatus)), style: (fg: "#80C8A1")),
                    (kind: Property(Widget(Volume)), style: (fg: "#80C8A1")),
                ],
            ),
            (
                left: [
                    (kind: Text("[ "), style: (fg: "#667688", modifiers: "Bold")),
                    (kind: Property(Status(StateV2(
                        playing_label: "PLAYING", paused_label: "PAUSED", stopped_label: "STOPPED",
                        playing_style: (fg: "#FFCF94", modifiers: "Bold"),
                        paused_style: (fg: "#FFCF94"),
                        stopped_style: (fg: "#4e4e4a"),
                    ))), style: (fg: "#4e4e4a")),
                    (kind: Text(" ]"), style: (fg: "#667688", modifiers: "Bold")),
                ],
                center: [
                    (kind: Property(Song(Artist)), style: (fg: "#C0CDD3", modifiers: "Bold"),
                        default: (kind: Text("Unknown"), style: (fg: "#C0CDD3", modifiers: "Bold"))),
                    (kind: Text(" - "), style: (fg: "#667688")),
                    (kind: Property(Song(Album)), style: (fg: "#8598B2"),
                        default: (kind: Text("Unknown Album"), style: (fg: "#8598B2"))),
                ],
                right: [
                    (kind: Property(Status(RepeatV2(
                        on_label: "REPEAT", off_label: "REPEAT",
                        on_style: (fg: "#FFCF94", modifiers: "Bold"),
                        off_style: (fg: "#4e4e4a"),
                    ))), style: (fg: "#4e4e4a")),
                    (kind: Text(" ╱ "), style: (fg: "#667688")),
                    (kind: Property(Status(RandomV2(
                        on_label: "RANDOM", off_label: "RANDOM",
                        on_style: (fg: "#FFCF94", modifiers: "Bold"),
                        off_style: (fg: "#4e4e4a"),
                    ))), style: (fg: "#4e4e4a")),
                    (kind: Text(" ╱ "), style: (fg: "#667688")),
                    (kind: Property(Status(ConsumeV2(
                        on_label: "CONSUME", off_label: "CONSUME",
                        oneshot_label: "CONSUME",
                                on_style: (fg: "#FFCF94", modifiers: "Bold"),
                        off_style: (fg: "#4e4e4a"),
                        oneshot_style: (fg: "#c2a27b"),
                    ))), style: (fg: "#4e4e4a")),
                    (kind: Text(" ╱ "), style: (fg: "#667688")),
                    (kind: Property(Status(SingleV2(
                        on_label: "SINGLE", off_label: "SINGLE",
                        oneshot_label: "SINGLE",
                        on_style: (fg: "#FFCF94", modifiers: "Bold"),
                        off_style: (fg: "#4e4e4a"),
                        oneshot_style: (fg: "#c2a27b"),
                    ))), style: (fg: "#4e4e4a")),
                ],
            ),
        ],
    ),
    layout: Split(
        direction: Vertical,
        panes: [
            (
                size: "4",
                borders: "ALL",
                pane: Split(
                    direction: Horizontal,
                    panes: [
                        (size: "2", pane: Pane(Empty())),
                        (size: "100%", pane: Pane(Header)),
                        (size: "2", pane: Pane(Empty())),
                    ],
                ),
            ),
            (
                size: "3",
                pane: Pane(Tabs),
            ),
            (
                size: "100%",
                borders: "ALL",
                pane: Split(
                    direction: Horizontal,
                    panes: [
                        (size: "1", pane: Pane(Empty())),
                        (size: "100%", pane: Pane(TabContent)),
                        (size: "1", pane: Pane(Empty())),
                    ],
                ),
            ),
            (
                size: "1",
                borders: "NONE",
                pane: Split(
                    direction: Horizontal,
                    panes: [
                        (size: "1", pane: Pane(Empty())),
                        (
                            size: "34",
                            pane: Pane(Property(
                                content: [
                                    (kind: Text("XFADE "), style: (fg: "#667688")),
                                    (kind: Property(Status(Crossfade)), style: (fg: "#667688"),
                                        default: (kind: Text("0"), style: (fg: "#667688"))),
                                    (kind: Text("s · "), style: (fg: "#667688")),
                                    (kind: Text("SONGS "), style: (fg: "#667688")),
                                    (kind: Property(Status(QueueLength())), style: (fg: "#667688"),
                                        default: (kind: Text("0"), style: (fg: "#667688"))),
                                    (kind: Text(" · "), style: (fg: "#667688")),
                                    (kind: Text("INDEX "), style: (fg: "#667688")),
                                    (kind: Property(Song(Track)), style: (fg: "#667688"),
                                        default: (kind: Text("-"), style: (fg: "#667688"))),
                                ],
                                align: Left,
                            )),
                        ),
                        (size: "100%", pane: Pane(Property(
                            content: [
                                (kind: Text("["), style: (fg: "#667688")),
                                (kind: Text("REM -"), style: (fg: "#a16f8c")),
                                (kind: Property(Status(QueueTimeRemaining())), style: (fg: "#a16f8c"),
                                    default: (kind: Text("0:00"), style: (fg: "#a16f8c"))),
                                (kind: Text("]  "), style: (fg: "#667688")),
                                (kind: Property(Status(QueueTimeTotal())), style: (fg: "#667688"),
                                    default: (kind: Text("0:00"), style: (fg: "#667688"))),
                            ],
                            align: Center,
                        ))),
                        (
                            size: "26",
                            pane: Pane(Property(
                                content: [
                                    (kind: Transform(Truncate(
                                        content: (kind: Property(Song(Other("date"))), style: (fg: "#667688")),
                                        length: 4,
                                        from_start: false,
                                    )), default: (kind: Text("----"), style: (fg: "#667688"))),
                                    (kind: Text(" · "), style: (fg: "#667688")),
                                    (kind: Property(Song(Bits())), style: (fg: "#667688"),
                                        default: (kind: Text("-"), style: (fg: "#667688"))),
                                    (kind: Text("bit · "), style: (fg: "#667688")),
                                    (kind: Property(Song(Channels())), style: (fg: "#667688"),
                                        default: (kind: Text("-"), style: (fg: "#667688"))),
                                    (kind: Text("ch · "), style: (fg: "#667688")),
                                    (kind: Property(Song(FileExtension)), style: (fg: "#667688"),
                                        default: (kind: Text("-"), style: (fg: "#667688"))),
                                ],
                                align: Right,
                            )),
                        ),
                        (size: "1", pane: Pane(Empty())),
                    ],
                ),
            ),
            (
                size: "20%",
                borders: "ALL",
                pane: Pane(Cava),
            ),
            (
                size: "3",
                borders: "ALL",
                pane: Split(
                    direction: Horizontal,
                    panes: [
                        (size: "2", pane: Pane(Empty())),
                        (size: "100%", pane: Pane(ProgressBar)),
                        (size: "1", pane: Pane(Empty())),
                        (
                            size: "14",
                            pane: Pane(Property(
                                content: [
                                    (kind: Property(Status(Elapsed)), style: (fg: "#667688")),
                                    (kind: Text(" / "), style: (fg: "#667688")),
                                    (kind: Property(Status(Duration)), style: (fg: "#667688")),
                                ],
                                align: Right,
                            )),
                        ),
                        (size: "2", pane: Pane(Empty())),
                    ],
                ),
            ),
        ],
    ),
)
