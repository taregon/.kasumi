#!/usr/bin/env bash
set -euo pipefail
# Notificación de escritorio al cambiar de canción.
# Dependencias: libnotify (notify-send), rmpc

ALBUM_ART_PATH="/tmp/rmpc_albumart.png"
rmpc albumart --output "$ALBUM_ART_PATH" 2> /dev/null || ALBUM_ART_PATH=""

# Mostrar título o "Unknown" si está vacío
TITLE_DISPLAY="${TITLE:-Unknown}"
ARTIST_DISPLAY="${ARTIST:-Unknown}"

notify-send \
    "Now Playing 󰽴" \
    "$TITLE_DISPLAY - $ARTIST_DISPLAY" \
    ${ALBUM_ART_PATH:+-i "$ALBUM_ART_PATH"} \
    || true # Notificación puede fallar en headless o sin display
