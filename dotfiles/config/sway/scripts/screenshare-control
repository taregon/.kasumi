#!/usr/bin/env bash
# screenshare-control
# Comparte pantalla de Sway/Wayland como cámara virtual V4L2.
#
# Uso: screenshare-control start [/dev/videoX] | stop
#
# Docs/refs:
#   - v4l2loopback: https://github.com/v4l2loopback/v4l2loopback/wiki
#   - Formato set-caps: <fourcc>:<width>x<height> (>= 2020, GStreamer-style deprecated)
#   - keep_format/sustain_framerate: controles V4L2 nativos de v4l2loopback
#   - --filter=hflip: corrige espejado horizontal (wf-recorder issue)
#
# Original: https://gist.github.com/telamon/23e5362757339bc8f22e9d40f9f1bd8e

set -euo pipefail

LOCKFILE="/tmp/screenshare-control.lock"
DEFAULT_DEVICE="/dev/video8"

# ────────────────────────────────────────────────────────────
screenshare_cleanup() {
    rm -f "$LOCKFILE"
    notify-send -t 1200 "󰍺  Screenshare" "Detenido"
}

virtual_camera_device=""

case "${1:-}" in
    stop)
        if [ -f "$LOCKFILE" ]; then
            pkill -SIGINT -x wf-recorder 2> /dev/null || true
            rm -f "$LOCKFILE"
            notify-send -t 1200 "󰍺  Screenshare" "Detenido"
        else
            notify-send -t 1200 "󰍺  Screenshare" "No está en ejecución"
        fi
        exit 0
        ;;

    start)
        virtual_camera_device="${2:-$DEFAULT_DEVICE}"
        ;;

    *)
        notify-send -t 1200 -u critical "󰍺  Screenshare" "Subcomando no reconocido: ${1:-}"
        exit 1
        ;;
esac

# ────────────────────────────────────────────────────────────
# Instancia única (evita múltiples wf-recorder al mismo tiempo).
exec 200> "$LOCKFILE"
if ! flock -n 200; then
    notify-send -t 1200 -u critical "󰍺  Screenshare" "Ya está en ejecución"
    exit 1
fi
trap screenshare_cleanup EXIT

# ────────────────────────────────────────────────────────────
# Obtiene resolución del monitor enfocado (swaymsg + jq).
read -r screen_width screen_height < <(
    swaymsg -t get_outputs -r \
        | jq -r '
        .[]
        | select(.focused == true)
        | "\(.current_mode.width) \(.current_mode.height)"
      '
)

screen_width="${screen_width:-1920}"
screen_height="${screen_height:-1080}"

# ────────────────────────────────────────────────────────────
# Verifica que el dispositivo V4L2 exista.
if [[ ! -e "$virtual_camera_device" ]]; then
    notify-send -t 1200 -u critical "󰍺  Screenshare" "Dispositivo no encontrado: $virtual_camera_device"
    exit 1
fi

# ────────────────────────────────────────────────────────────
# Configura formato V4L2.
#
# Orden correcto (>= 2020): <device> <caps> (el inverso es deprecated)
# Formato correcto: YUYV:<width>x<height> (GStreamer-style es deprecated)
#
# keep_format=0: desbloquea por si quedó bloqueado de ejecución anterior
# v4l2loopback-ctl set-caps: ya activa keep_format=1 automáticamente
# sustain_framerate=1: mantiene FPS estables (útil para WebRTC)
v4l2-ctl -d "$virtual_camera_device" -c keep_format=0 || true # Desbloquea por si quedó bloqueado; || true por set -e

v4l2loopback-ctl set-caps \
    "$virtual_camera_device" \
    "YUYV:${screen_width}x${screen_height}" # Formato correcto (>= 2020): <device> <caps>. GStreamer-style es deprecated.

v4l2-ctl -d "$virtual_camera_device" -c sustain_framerate=1 # Mantiene FPS estables (WebRTC)

# ────────────────────────────────────────────────────────────
notify-send -t 5000 "󰍺  Screenshare" "Iniciando: ${screen_width}x${screen_height} @ ${virtual_camera_device}"

# Nota sobre hflip:
#   - Corrige espejado horizontal para quien comparte.
#   - A veces Discord muestra invertido para TI, pero normal para los demás.
#   - Si los demás participantes lo ven invertido, quita este flag.
wf-recorder \
    --muxer=v4l2 \
    --file="$virtual_camera_device" \
    -c rawvideo \
    -x yuyv422 \
    --filter=hflip
