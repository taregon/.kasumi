#!/bin/bash
# cava-bar — Cava audio visualizer para Waybar

set -euo pipefail

# ── Setup ─────────────────────────────────────────────────────────────────

# Guardia de instancia única vía PID file
pid_file="/tmp/waybar-cava.pid"
kill "$(cat "$pid_file" 2> /dev/null)" 2> /dev/null || true
printf '%d' $$ > "$pid_file"

# Glifos de barra: 0..7 -> ▁▂▃▄▅▆▇█
bar_glyphs="▁▂▃▄▅▆▇█"
sed_script="s/;//g"
bar_length=${#bar_glyphs}
for ((i = 0; i < bar_length; i++)); do
    sed_script+=";s/$i/${bar_glyphs:$i:1}/g"
done
sed_script+=";s/./& /g"

config_file=$HOME/.config/cava/cava-waybar.conf
cat > "$config_file" << 'EOF'
[general]
bars = 12
framerate = 30
sensitivity = 250

[smoothing]
monstercat = 0
gravity = 200
noise_reduction = 0.3

[output]
method = raw
raw_target = /dev/stdout
data_format = ascii
ascii_max_range = 7
EOF

# ── Pipeline ──────────────────────────────────────────────────────────────

cava -p "$config_file" | sed -u "$sed_script"
