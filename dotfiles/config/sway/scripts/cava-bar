#!/usr/bin/bash
# cava-bar — Cava audio visualizer para Waybar

set -euo pipefail

# ── Setup ─────────────────────────────────────────────────────────────────

config_file="$HOME/.config/cava/cava-waybar.conf"

# Evita múltiples instancias de cava compitiendo por el dispositivo de audio
pkill -f "cava -p $config_file" 2> /dev/null || true
sleep 0.1

# Cava emite dígitos 0-7; sed los reemplaza por glifos de barra en la salida:
# 0→▁ 1→▂ 2→▃ 3→▄ 4→▅ 5→▆ 6→▇ 7→█
# Idea problable "⢀⢠⢰⢸"
bar_glyphs="▁▂▃▄▅▆▇█"
sed_script="s/;//g"
bar_length=${#bar_glyphs}
for ((i = 0; i < bar_length; i++)); do
    sed_script+=";s/$i/${bar_glyphs:$i:1}/g"
done
sed_script+=";s/./& /g"

cat > "$config_file" << 'EOF'
[general]
bars = 12
framerate = 45
sensitivity = 250
lower_cutoff_freq = 70
higher_cutoff_freq = 9000

[smoothing]
monstercat = 0
gravity = 200
noise_reduction = 0.3

[input]
method = pipewire

[output]
method = raw
raw_target = /dev/stdout
data_format = ascii
ascii_max_range = 7
EOF

# ── Pipeline ──────────────────────────────────────────────────────────────

cava -p "$config_file" | sed -u "$sed_script"
