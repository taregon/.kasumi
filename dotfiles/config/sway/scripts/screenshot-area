#!/usr/bin/env bash
# Captura de pantalla con slurp para Sway
# Uso: screenshot-area [region|window|swappy]
#   region  (default) - selecciona área, guarda y copia al clipboard
#   window            - selecciona ventana, guarda y copia
#   swappy            - selecciona área y abre swappy para editar antes de guardar
# Cancela con ESC. No guarda nada si no hay selección

# Variables
OUTPUT_DIR="${KASUMI_SCREENSHOT_DIR:-$HOME}" # Directorio donde se guardan las capturas
DATE=$(date +%Y%m%d)                         # Fecha actual en formato YYYYMMDD
FILE_PREFIX="shot"                           # Prefijo de archivos (cambiar si se desea)

# # Crear directorio si no existe
# if [ ! -d "$OUTPUT_DIR" ]; then
#     mkdir -p "$OUTPUT_DIR"
# fi

# Numeración automática
# Busca el mayor número de archivo del día (formato: prefix-YYYYMMDD-NNN.png)
LAST_NUM=0
for file in "$OUTPUT_DIR"/"${FILE_PREFIX}-${DATE}"-[0-9][0-9][0-9].png; do
    num=${file##*-} # extrae "NNN.png"
    num=${num%.png} # quita extensión
    ((10#$num > LAST_NUM)) && LAST_NUM=$((10#$num))
done

NEXT_NUM=$((LAST_NUM + 1))
FILENAME="$OUTPUT_DIR/${FILE_PREFIX}-${DATE}-$(printf "%03d" $NEXT_NUM).png"

# Argumentos para slurp (estilo visual)
KASUMI_SLURP_ARGS=(
    -b '#65001e60' # color de fondo (transparente)
    -c '#F86E88'   # color del borde
    -w 2           # ancho del borde
    -F 'monospace' # fuente
    -d             # muestra dimensiones en tiempo real
)

MODE="${1:-region}" # Primer argumento: region (default)

# Función de captura
# Flujo: slurp (selección) -> grim (captura) -> salida (guarda/copia/swappy)
# Retorna 1 si el usuario cancela (sin selección)
capture() {
    case "$MODE" in
        window)
            GEOMETRY=$(swaymsg -t get_tree | jq -r '.. | select(.pid? and .visible?) | .rect | "\(.x),\(.y) \(.width)x\(.height)"' | slurp -f '%x,%y %wx%h')
            ;;
        *)
            GEOMETRY=$(slurp "${KASUMI_SLURP_ARGS[@]}")
            ;;
    esac

    [ -z "$GEOMETRY" ] && return 1

    case "$MODE" in
        window)
            grim -g "$GEOMETRY" - | tee "$FILENAME" | wl-copy
            ;;
        swappy)
            grim -g "$GEOMETRY" - | swappy -f -
            ;;
        *)
            grim -g "$GEOMETRY" - | tee "$FILENAME" | wl-copy
            ;;
    esac
}

# Notificaciones
if capture; then
    # swappy maneja su propia notificación interna
    if [ "$MODE" != "swappy" ]; then
        notify-send "󰹗 Captura copiada y guardada" "$(basename "$FILENAME")"
    fi
else
    notify-send -u critical "Error en captura" "No se pudo capturar la región"
fi
