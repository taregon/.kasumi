#!/usr/bin/env bash

# Captura de área: región con slurp o ventana seleccionada → guarda en ~/Imágenes + copia al clipboard + notifica

OUTPUT_DIR="$HOME/Imágenes/Screenshots/"
FILENAME="$OUTPUT_DIR/captura-$(date +%Y-%m-%d_%H-%M-%S).png"

KASUMI_SLURP_ARGS=(
    -b '#2810145d'
    -c '#F86E88'
    -w 2
    -F 'monospace'
    -d
)

if [ ! -d "$OUTPUT_DIR" ]; then
    mkdir -p "$OUTPUT_DIR"
fi

MODE="${1:-region}"

capture() {
    case "$MODE" in
        window)
            GEOMETRIA=$(swaymsg -t get_tree | jq -r '.. | select(.pid? and .visible?) | .rect | "\(.x),\(.y) \(.width)x\(.height)"' | slurp -f '%x,%y %wx%h') # Aquí usas el default de -f para grim
            grim -g "$GEOMETRIA" - | tee "$FILENAME" | wl-copy
            ;;
        swappy | edit)
            grim -g "$(slurp "${KASUMI_SLURP_ARGS[@]}")" - | tee >(wl-copy) | swappy -f -
            ;;
        region | *)
            grim -g "$(slurp "${KASUMI_SLURP_ARGS[@]}")" - | tee "$FILENAME" | wl-copy
            ;;
    esac
}

if capture; then
    notify-send "󰹗 Captura copiada y guardada" "$(basename "$FILENAME")"
else
    notify-send -u critical "Error en captura" "No se pudo capturar la región"
fi
