#!/usr/bin/env bash

OUTPUT_DIR="$HOME/Imágenes/Screenshots/"
FILENAME="$OUTPUT_DIR/captura-$(date +%Y-%m-%d_%H-%M-%S).png"
KASUMI_SLURP_ARGS=(
    -b '#2810145d'
    -c '#F86E88'
    -w 2
    -F 'monospace'
    -d
)

if [ ! -d "$OUTPUT_DIR" ]; then
    mkdir -p "$OUTPUT_DIR"
fi

MODE="${1:-region}"

# Obtiene selección del usuario con slurp,
# verifica que no esté vacía y captura con grim
capture() {
    case "$MODE" in
        window)
            GEOMETRY=$(swaymsg -t get_tree | jq -r '.. | select(.pid? and .visible?) | .rect | "\(.x),\(.y) \(.width)x\(.height)"' | slurp -f '%x,%y %wx%h')
            [ -z "$GEOMETRY" ] && return 1
            grim -g "$GEOMETRY" - | tee "$FILENAME" | wl-copy
            ;;
        swappy)
            GEOMETRY=$(slurp "${KASUMI_SLURP_ARGS[@]}")
            [ -z "$GEOMETRY" ] && return 1
            grim -g "$GEOMETRY" - | swappy -f -
            ;;
        region | *)
            GEOMETRY=$(slurp "${KASUMI_SLURP_ARGS[@]}")
            [ -z "$GEOMETRY" ] && return 1
            grim -g "$GEOMETRY" - | tee "$FILENAME" | wl-copy
            ;;
    esac
}

if capture; then
    if [ "$MODE" != "swappy" ]; then
        notify-send "󰹗 Captura copiada y guardada" "$(basename "$FILENAME")"
    fi
else
    notify-send -u critical "Error en captura" "No se pudo capturar la región"
fi
