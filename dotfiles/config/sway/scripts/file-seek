#!/usr/bin/env bash
# Busca archivos en directorios fijos y los abre via rofi + xdg-open

# Directorios base donde buscar archivos
dirs=(
    # "$(zoxide query)"
    "$HOME/Documentos"
    "$HOME/Descargas"
    "$HOME/Syncthing/OsiriaFS"
)

# -show-icons: muestra iconos via XDG thumbnailers (prefijo thumbnail:// en la entrada)
# short_path: reemplaza $HOME por ~ en la ruta mostrada en rofi

selection="$(
    fd . "${dirs[@]}" \
        --type f \
        --hidden \
        --exclude .git \
        | while read -r file; do
            short_path="$(printf '%s\n' "$file" | sed "s|^$HOME|~|")"
            printf '%s\0icon\x1fthumbnail://%s\n' \
                "$short_path" "$file"
        done \
        | rofi -dmenu -show-icons -p "Files" -matching glob -case-smart -sort \
            -theme-str '
            listview { lines: 8; columns: 1; dynamic: true; }
            element { padding: 6px; }
            element-icon { size: 56px; }
            mainbox {
                children: [ inputbar, listview ];
            }
        '
)"

# Expande ~ inicial a $HOME y abre el archivo con xdg-open
[[ -n "$selection" ]] && xdg-open "${selection/#\~/$HOME}"
