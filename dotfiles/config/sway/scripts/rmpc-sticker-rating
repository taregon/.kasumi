#!/usr/bin/env bash
# Stickers de rating para filtrar canciones por calidad en rmpc
set -euo pipefail

file=$(mpc current --format '%file%')
[ -n "$file" ] || exit 0

mpc sticker "$file" set rating "$1"

case "$1" in
    0) notify-send "уұҷқ  Descartada" ;;
    1) notify-send "пҖҶ  Regular" ;;
    2) notify-send "пҖҶ пҖҶ  Buena" ;;
    3) notify-send "пҖҶ пҖҶ пҖҶ  Excelente" ;;
esac
