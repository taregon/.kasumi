#!/usr/bin/env bash
# Captura de pantalla con slurp para Sway
# Uso: screenshot-area [region|window|swappy]
#   region  (default) - selecciona área, guarda y copia al clipboard
#   window            - selecciona ventana, guarda y copia
#   swappy            - selecciona área y abre swappy para editar antes de guardar
# Cancela con ESC. No guarda nada si no hay selección

set -uo pipefail

EXIT_CANCEL=2
OUTPUT_DIR="${KASUMI_SCREENSHOT_DIR:-$HOME}"

# Argumentos para slurp (estilo visual)
KASUMI_SLURP_ARGS=(
    -b '#A4084C4D' # overlay global semitransparente fuera de la selección
    -B '#2E383D94' # relleno de ventanas/regiones precargadas
    -c '#FC697C'   # color del borde
    -w 2           # ancho del borde
    -F 'monospace' # fuente
    -d             # muestra dimensiones en tiempo real
)

MODE="${1:-region}" # Primer argumento: region (default)

# Solo se necesita FILENAME si se guarda archivo (no en modo swappy)
[ "$MODE" != "swappy" ] && FILENAME="$OUTPUT_DIR/shot-$(date +%Y%m%d-%H%M%S).png"

# Función de captura
# Flujo: slurp (selección) -> grim (captura) -> salida (guarda+copia, o swappy)
# Retorna 0 éxito, $EXIT_CANCEL si el usuario cancela (sin selección), otro si error
capture() {
    local GEOMETRY

    case "$MODE" in
        window)
            GEOMETRY=$(
                swaymsg -t get_tree | jq -r '
                recurse(.nodes[]?, .floating_nodes[]?)
                | select(.pid and .visible == true)
                | "\(.rect.x),\(.rect.y) \(.rect.width)x\(.rect.height)"' \
                    | slurp -r -f '%x,%y %wx%h' "${KASUMI_SLURP_ARGS[@]}"
            )
            ;;
        region | swappy)
            GEOMETRY=$(slurp "${KASUMI_SLURP_ARGS[@]}")
            ;;
    esac

    [ -z "$GEOMETRY" ] && return $EXIT_CANCEL # Sin selección -> cancelación

    case "$MODE" in
        swappy)
            # grim captura y pasa la imagen por tubería a swappy, que la muestra para editar
            grim -g "$GEOMETRY" - | swappy -f -
            ;;
        region | window)
            grim -g "$GEOMETRY" - | tee "$FILENAME" | wl-copy -t image/png --paste-once
            ;;
    esac
}

# Notificaciones
capture
capture_status=$?
if [ $capture_status -eq 0 ]; then
    # swappy maneja su propia notificación interna
    [ "$MODE" != "swappy" ] && notify-send "󰹗 Captura copiada y guardada" "$(basename "$FILENAME")"
elif [ $capture_status -ne $EXIT_CANCEL ]; then
    notify-send -u critical "Error en captura" "No se pudo capturar la región"
fi
