#!/usr/bin/env bash
# region-record
# Graba una región de pantalla en Sway/Wayland como archivo de video.
#
# Uso: region-record start | stop
#
# Mejora posible: usar VAAPI para reducir drásticamente el uso de CPU
#   wf-recorder -c h264_vaapi -d /dev/dri/renderD128 ...
#   (requiere wf-recorder compilado con soporte VAAPI)

set -euo pipefail

LOCKFILE="/tmp/region-record.lock"
OUTPUT_DIR="${KASUMI_RECORDING_DIR:-$HOME}"

# PID del watchdog para finalizarlo explícitamente durante cleanup().
WATCHDOG_PID=""

cleanup() {
    [ -f "$LOCKFILE" ] || return 0

    rm -f "$LOCKFILE"

    # Finaliza el watchdog si aún sigue activo.
    # `|| true` evita abortar si el proceso ya no existe.
    if [ -n "$WATCHDOG_PID" ]; then
        kill "$WATCHDOG_PID" 2> /dev/null || true
    fi

    notify-send -t 1200 \
        "󰿏  Grabación" \
        "Finalizada"
}

watchdog_loop() {
    local elapsed
    local interval
    local message
    local notify_id
    local size
    local start_time

    start_time=$(date +%s)
    interval="${KASUMI_WATCHDOG_INTERVAL:-12}"

    # cleanup() elimina el lock al finalizar; eso detiene el watchdog.
    while [ -f "$LOCKFILE" ]; do
        sleep "$interval"

        size=$(stat -c%s "$filename" 2> /dev/null || echo 0)

        # wf-recorder aún no escribió datos útiles.
        [ "$size" -gt 0 ] || continue

        elapsed=$(
            date -d "@$(($(date +%s) - start_time))" \
                -u +%H:%M:%S
        )

        message="$(
            basename "$filename"
        ) · $elapsed · $(numfmt --to=iec "$size")"

        if [ -n "${notify_id:-}" ]; then
            notify-send \
                --replace-id="$notify_id" \
                -t 0 \
                "󰿏  Grabación" \
                "$message"
        else
            notify_id=$(
                notify-send \
                    -p \
                    -t 0 \
                    "󰿏  Grabación" \
                    "$message"
            )
        fi
    done
}

stop_recording() {
    if [ -f "$LOCKFILE" ]; then
        # SIGINT permite que wf-recorder cierre limpiamente
        # el contenedor y finalice correctamente el video.
        pkill -SIGINT -x wf-recorder 2> /dev/null || true

        cleanup
    else
        notify-send -t 1200 \
            "󰿏  Grabación" \
            "No hay ninguna activa"
    fi

    exit 0
}

start_recording() {
    local geometry
    local filename

    # slurp se ejecuta antes de adquirir el lock:
    # si el usuario cancela la selección (ESC),
    # el script termina sin dejar estado parcial.
    geometry=$(slurp -w 0 -f '%x,%y %wx%h') || exit 0

    exec 200> "$LOCKFILE"

    if ! flock -n 200; then
        notify-send -t 1200 -u critical \
            "󰿏  Grabación" \
            "Ya hay una activa"

        exit 1
    fi

    # Garantiza limpieza del lock y procesos auxiliares
    # sin importar cómo termine el script:
    # error interno, señal externa o Ctrl+C.
    trap cleanup EXIT INT TERM

    filename="$OUTPUT_DIR/rec-$(date +%Y%m%d-%H%M%S).mkv"

    notify-send -t 3000 \
        "󰿏  Grabación" \
        "Región → $filename"

    # Watchdog en background:
    # muestra duración y tamaño del archivo cada
    # KASUMI_WATCHDOG_INTERVAL segundos.
    watchdog_loop &
    WATCHDOG_PID=$!

    wf-recorder \
        -g "$geometry" \
        --file="$filename"
}

case "${1:-start}" in
    start)
        start_recording
        ;;
    stop)
        stop_recording
        ;;
    *)
        notify-send -t 1200 -u critical \
            "󰿏  Grabación" \
            "Subcomando no reconocido: ${1:-}"

        exit 1
        ;;
esac
