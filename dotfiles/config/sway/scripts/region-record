#!/usr/bin/env bash
# region-record
# Graba una región de pantalla en Sway/Wayland como archivo de video.
#
# Uso: region-record start | stop
#
# Mejora posible: usar VAAPI para reducir drásticamente el uso de CPU
#   wf-recorder -c h264_vaapi -d /dev/dri/renderD128 ...
#   (requiere wf-recorder compilado con soporte VAAPI)

set -euo pipefail

LOCKFILE="/tmp/region-record.lock"
OUTPUT_DIR="${KASUMI_RECORDING_DIR:-$HOME}"

recording_started=0 # Flag que distingue entre proceso start (wf-recorder activo) y proceso stop (solo limpieza)

cleanup() {
    # Si el lock ya fue removido por otro proceso (stop), esta llamada no hace nada.
    [ -f "$LOCKFILE" ] || return 0

    rm -f "$LOCKFILE"

    if [ "$recording_started" -eq 1 ]; then
        notify-send -t 1200 "󰿏  Grabación" "Detenida"
    fi
}

stop_recording() {
    if [ -f "$LOCKFILE" ]; then
        # SIGINT cierra limpiamente el contenedor/video
        pkill -SIGINT -x wf-recorder 2> /dev/null || true # Si wf-recorder ya no existe (crash previo), pkill falla; || true mantiene la ejecucion

        cleanup
    else
        notify-send -t 1200 "󰿏  Grabación" "No hay grabación activa"
    fi

    exit 0
}

start_recording() {
    local geometry
    local filename

    # Slurp se ejecuta antes de adquirir el lock: si se cancela la seleccion (ESC), el script termina
    # sin adquirir el lock ni disparar el trap de limpieza.
    geometry=$(slurp -w 0 -f '%x,%y %wx%h') || exit 0

    exec 200> "$LOCKFILE"

    if ! flock -n 200; then
        notify-send -t 1200 -u critical \
            "󰿏  Grabación" \
            "Ya hay una grabación activa"
        exit 1
    fi

    trap cleanup EXIT INT TERM # Garantiza limpieza del lock sin importar como termine: stop externo, error interno, o Ctrl+C

    filename="$OUTPUT_DIR/rec-$(date +%Y%m%d-%H%M%S).mkv"

    notify-send -t 3000 \
        "󰿏  Grabación" \
        "Grabando región → $(basename "$filename")"

    recording_started=1

    wf-recorder \
        -g "$geometry" \
        --file="$filename"
}

case "${1:-start}" in
    start)
        start_recording
        ;;
    stop)
        stop_recording
        ;;
    *)
        notify-send -t 1200 -u critical \
            "󰿏  Grabación" \
            "Subcomando no reconocido: ${1:-}"
        exit 1
        ;;
esac
