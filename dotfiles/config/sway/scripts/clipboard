#!/usr/bin/env bash
# Historial de portapapeles con rofi
# Modos:
#   text  -> solo texto
#   image -> solo imágenes con preview

# Salir ante error, variable indefinida o pipe roto
set -euo pipefail

case "$1" in
    text)
        seleccion=$(
            # Listar historial, filtrar solo entradas de texto (no binarias)
            cliphist list \
                | grep -Fv '[[ binary data' \
                | rofi -dmenu \
                    -p "󰯗  Historial de texto:" \
                    -display-columns 2 \
                    -theme-str '
                        element-icon { size: 0%; }
                        listview {columns: 1; }
                        mode-switcher { enabled: false; }
                    '
        )
        ;;

    image)
        # Directorio temporal para previews de imágenes
        tmp_dir=$(mktemp -d)
        # Limpiar directorio temporal al salir
        trap 'rm -rf "$tmp_dir"' EXIT

        seleccion=$(
            # Listar historial, filtrar solo entradas binarias (imágenes)
            # Limita la cantidad de minuaturas con head
            cliphist list \
                | grep -F '[[ binary data' \
                | head -n 12 \
                | while IFS= read -r line; do
                    # Extraer ID numérico del formato "ID<TAB>contenido"
                    id="${line%% *}"
                    img="$tmp_dir/$id"

                    # Decodificar binario a archivo temporal para preview en rofi
                    cliphist decode <<< "$line" > "$img"

                    # Formato rofi icon row: "línea\0icon\x1f/ruta/imagen"
                    printf '%s\0icon\x1f%s\n' \
                        "$line" \
                        "$img"
                done \
                | rofi -dmenu \
                    -p "󰯕  Historial de imágenes:" \
                    -display-columns 2 \
                    -theme-str '
                        element { border-radius: 8px; orientation: vertical; padding: 6px; }
                        element-icon { size: 128px; horizontal-align: 0.5; vertical-align: 0.5; padding: 2px; }
                        element-text { enabled: false; }
                        listview { columns: 3; lines: 2; spacing: 10px; }
                        mode-switcher { enabled: false; }
                        window { width: 30%; }
                '
            # Mas ajustes para rofi
            # https://davatorium.github.io/rofi/current/rofi-theme.5/
        )
        ;;

    *)
        notify-send \
            "Cliphist" \
            "Modo inválido: usar 'text' o 'image'" \
            -u critical

        exit 1
        ;;
esac

# Copiar selección al portapapeles
if [ -n "$seleccion" ]; then
    # Decodificar y copiar con wl-copy
    if printf '%s\n' "$seleccion" | cliphist decode | wl-copy; then
        notify-send \
            "Cliphist" \
            "Contenido copiado al portapapeles" \
            -t 1200
    else
        notify-send \
            "Cliphist" \
            "Error al copiar contenido" \
            -u critical
    fi
fi
