#!/usr/bin/env bash
# Historial de portapapeles con rofi
# Modos:
#   text  -> solo texto
#   image -> solo imágenes con preview

set -euo pipefail

case "$1" in
    text)
        seleccion=$(
            cliphist list \
                | grep -Fv '[[ binary data' \
                | rofi -dmenu \
                    -p " Historial texto" \
                    -display-columns 2 \
                    -theme-str '
                        listview {
                            columns: 1;
                        }
                    '
        )
        ;;

    image)
        tmp_dir=$(mktemp -d)
        trap 'rm -rf "$tmp_dir"' EXIT

        seleccion=$(
            cliphist list \
                | grep -F '[[ binary data' \
                | while IFS= read -r line; do
                    id="${line%% *}"
                    img="$tmp_dir/$id"

                    cliphist decode <<< "$line" > "$img"

                    printf '%s\0icon\x1f%s\n' \
                        "$line" \
                        "$img"
                done \
                | rofi -dmenu \
                    -p "󰋩 Historial imágenes" \
                    -display-columns 2 \
                    -theme-str '
                        listview {
                            columns: 1;
                        }

                        element-icon {
                            size: 64px;
                        }
                    '
        )
        ;;

    *)
        notify-send \
            "Cliphist" \
            "Modo inválido: usar 'text' o 'image'" \
            -u critical

        exit 1
        ;;
esac

if [ -n "$seleccion" ]; then
    if printf '%s\n' "$seleccion" | cliphist decode | wl-copy; then
        notify-send \
            "Cliphist" \
            "Contenido copiado al portapapeles" \
            -t 1200
    else
        notify-send \
            "Cliphist" \
            "Error al copiar contenido" \
            -u critical
    fi
fi
