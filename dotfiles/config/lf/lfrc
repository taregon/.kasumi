  set shell zsh
  set shellopts '-eu'
  set ifs "\n"

  set dircounts true
  set drawbox true
  set incsearch true
  set ignorecase true
  set period 3
  set preview true
  set scrolloff 10
  set sortby ctime
  set icons true

  set previewer ~/.config/lf/lfpreview
  set ratios 1:2:2
  set info ctime:size

  set infotimefmtnew "Jan _2 2006"
  set infotimefmtold "Jan _2 2006"

  map <delete> delete
  map <enter> open

  map X %trash-put  "$fx"
  map a push $mkdir<space>

# Copia la ruta del archivo
  map Y %echo -n "$f" | wl-copy
  map o %ripdrag -W 400 -H 200 -s 195 -bx "$f"

