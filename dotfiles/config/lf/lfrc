  }}

# FZF JUMP
# BГәsqueda rГЎpida de archivos y directorios mediante fd + fzf.
# Reutiliza FZF_CTRL_T_COMMAND definido en zshrc para mantener
# las mismas exclusiones y opciones.
cmd fzf_jump ${{
    # Reemplazamos --type f por --type f --type d de forma mГЎs limpia
    cmd_search="${FZF_CTRL_T_COMMAND/--type f/--type f --type d}"

    res="$(eval "$cmd_search" 2>/dev/null | \
           fzf --reverse --header=' Jump to location ' --prompt='вқҜ ')"

    [ -z "$res" ] && exit

    if [ -d "$res" ]; then
        lf -remote "send $id cd \"$res\""
    else
        lf -remote "send $id select \"$res\""
    fi
}}

map <c-f> :fzf_jump

# FZF SEARCH (Content)
# BГәsqueda de texto dentro de archivos usando ripgrep + fzf.
# Recarga dinГЎmica mientras se escribe.
cmd fzf_search ${{
    RG_PREFIX="rg --column --line-number --no-heading --color=always --smart-case --hidden"

    res="$(
        FZF_DEFAULT_COMMAND="$RG_PREFIX ''" \
        fzf --bind "change:reload:$RG_PREFIX {q} || true" \
            --ansi --layout=reverse --header='Search in files' \
            --preview 'bat --color=always --style=plain {1} --highlight-line {2}' \
            --delimiter ':' \
            2>/dev/null | cut -d':' -f1
    )"

    [ -n "$res" ] && lf -remote "send $id select \"$res\""
}}

map <c-g> :fzf_search
