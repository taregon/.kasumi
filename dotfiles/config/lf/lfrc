# https://man.archlinux.org/man/lf.1.en
# ────────────────────────────────────────────────────────────
  set shell zsh
  set shellopts '-eu'
  set ifs "\n"

  set dircounts true
  set drawbox true
  set icons true
  set ignorecase true
  set incsearch true
  set period 3
  set preview true
  set scrolloff 10

  set previewer ~/.config/lf/lfpreview
  set ratios 1:2:2

  set info ctime:size
  set infotimefmtnew "Jan _2 2006"
  set infotimefmtold "Jan _2 2006"
  set sortby ctime

# ╒═════════════════════════════════════════════════════════════╕
# │                           ATAJOS                            │
# ╘═════════════════════════════════════════════════════════════╛
  map <delete> delete
  map <enter> open

  map . set hidden!
  map X %trash-put  "$fx"
  map a push $mkdir<space>

  map gN cd ~/Syncthing/OsiriaFS/Notas

# Copia la ruta del archivo
  map Y %echo -n "$f" | wl-copy

# Abre una ventana GTK4, carga archivos desde CLI
# y permite arrastrarlos a aplicaciones gráficas
  map o %ripdrag -W 400 -H 200 -s 195 -bx "$f"

# map C $cat "$fx" | wl-copy
