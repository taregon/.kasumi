# ╒═════════════════════════════════════════════════════════════╕
# │                    NAVEGACIÓN Y BÚSQUEDA                    │
# ╘═════════════════════════════════════════════════════════════╛
# Forzar redraw completo tras cada selección (crucial en tmux)
cmd on-select &{{
  lf -remote "send $id redraw"
}}

# ─[ FZF JUMP ]─────────────────────────────────────────────────
# Búsqueda rápida de archivos y directorios mediante fd + fzf.
# Reutilización de FZF_CTRL_T_COMMAND desde zshrc.
# Preserva exclusiones y opciones configuradas.
cmd fzf_jump ${{
  # Reemplaza --type f por --type f --type d de forma más limpia
  fd_cmd="${FZF_CTRL_T_COMMAND/--type f/--type f --type d}"

  selected_path="$(eval "$fd_cmd" 2>/dev/null | \
    fzf --reverse --header='  Buscar archivo')"

  [ -z "$selected_path" ] && exit

  if [ -d "$selected_path" ]; then
    lf -remote "send $id cd \"$selected_path\""
  else
    lf -remote "send $id select \"$selected_path\""
  fi
}}

  map <c-f> :fzf_jump

# ─[ FZF SEARCH ]───────────────────────────────────────────────
# Búsqueda de contenido en archivos mediante ripgrep + fzf.
# Recarga dinámica al modificar la consulta.
cmd fzf_ripgrep ${{
  rg_cmd="rg --column --line-number --no-heading --color=always --smart-case"

  fzf --ansi \
    --disabled \
    --header='  Buscar archivos usando su contenido' \
    --delimiter ':' \
    --bind "change:reload:$rg_cmd {q} || true" \
    --bind "enter:execute(lf -remote 'send $id select \"{1}\"')+abort" \
    --preview '[ -n {2} ] && bat --color=always --style=plain {1} --highlight-line {2}' \
    2>/dev/null
}}

  map <c-g> :fzf_ripgrep
