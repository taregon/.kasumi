#!/usr/bin/env bash

set -o noclobber -o noglob -o nounset -o pipefail

FILE_PATH="$1"
PREVIEW_WIDTH="$2"
PREVIEW_HEIGHT="$3"
PREVIEW_X="$4"
PREVIEW_Y="$5"
THUMB_SIZE=800
CACHE_DIR="${XDG_CACHE_HOME:-"$HOME/.cache"}/lf"
mkdir -p "$CACHE_DIR"

create_cache() {
    realfile="$(readlink -f "$FILE_PATH" || realpath "$FILE_PATH")"
    CACHE="${CACHE_DIR}/thumb-$(stat --printf '%i\0%s\0%Y' "$realfile" | xxhsum -q | cut -d' ' -f1)"
}

create_thumb() {
    magick "$FILE_PATH" \
        -auto-orient \
        -define jpeg:optimize-coding=true \
        -define jpeg:sampling-factor=4:2:0 \
        -thumbnail "${THUMB_SIZE}x${THUMB_SIZE}>" \
        "${CACHE}.jpg" 2> /dev/null
}

draw_ascii() {
    chafa \
        -s "${PREVIEW_WIDTH}x${PREVIEW_HEIGHT}" \
        --animate off \
        --colors 240 \
        --work 4 \
        --fg-only \
        --format symbols \
        --polite off \
        --symbols ascii \
        "$FILE_PATH"
}

draw_kitty() {
    local img="${1:-$FILE_PATH}"
    kitty +kitten icat --silent --stdin no --transfer-mode memory \
        --place "${PREVIEW_WIDTH}x${PREVIEW_HEIGHT}@${PREVIEW_X}x${PREVIEW_Y}" "$img" < /dev/null > /dev/tty
}

MIMETYPE="$(file -L --brief --mime-type "$FILE_PATH")"

case "$MIMETYPE" in
    */epub+zip | */x-fictionbook+xml)
        pandoc -s -t markdown "$FILE_PATH" | bat -l markdown --color=always --paging=never --terminal-width="$PREVIEW_WIDTH"
        ;;
    application/json)
        jq -C "." "$FILE_PATH" 2> /dev/null || bat --color=always --paging=never --style=plain --terminal-width="$PREVIEW_WIDTH" "$FILE_PATH"
        ;;
    application/pdf)
        create_cache
        [ -f "${CACHE}.jpg" ] || pdftoppm -jpeg -f 1 \
            -scale-to "$THUMB_SIZE" \
            -jpegopt quality=70,progressive=y,optimize=y \
            -singlefile "$FILE_PATH" "$CACHE" 2> /dev/null
        draw_kitty "${CACHE}.jpg" || draw_ascii
        ;;
    application/x-bittorrent)
        aria2c -S "$FILE_PATH" 2> /dev/null
        ;;
    application/zip)
        unzip -l "$FILE_PATH"
        ;;
    application/x-7z-compressed | application/x-rar | application/x-tar | application/gzip | application/x-bzip2 | application/x-xz | application/x-rpm | application/java-archive)
        7z l "$FILE_PATH"
        ;;
    audio/*)
        mpv --audio-display=no "$FILE_PATH"
        # mediainfo "$FILE_PATH"
        ;;
    image/gif)
        draw_ascii
        ;;
    image/*)
        create_cache
        [ -f "${CACHE}.jpg" ] || create_thumb
        draw_kitty "${CACHE}.jpg" || draw_ascii
        ;;
    text/* | */xml)
        bat --color=always --paging=never --style=plain --terminal-width="$PREVIEW_WIDTH" "$FILE_PATH"
        ;;
    video/*)
        create_cache
        [ -f "${CACHE}.jpg" ] || ffmpegthumbnailer -i "$FILE_PATH" -o "${CACHE}.jpg" -s 0 -c jpeg
        draw_kitty "${CACHE}.jpg"
        ;;
esac

exit 1
