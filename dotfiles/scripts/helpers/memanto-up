#!/usr/bin/env bash
# Inicia MEMANTO + Moorcheh (backend vectorial) para memoria persistente.
# Ruta: ~/.local/bin/kasumi/helpers/memanto-up
# Idempotente: verifica estado antes de iniciar.

set -euo pipefail

# ── Fix: red host + permisos para embeddings ─────────────────────────
# Si moorcheh queda con items:0 y el job de embedding falla con
# "failed calling ollama embeddings endpoint", aplicar estos pasos:
#
# 1. En ambos venvs (memanto y moorcheh-client):
#    site-packages/moorcheh/compose/docker-compose.yml
#    - Agregar: network_mode: host
#    - Quitar: ports, extra_hosts (incompatibles con host network)
#
# 2. En docker_runtime.py y user_config.py de ambos venvs:
#    - Reemplazar host.docker.internal → 127.0.0.1
#    (El contenedor comparte red del host, localhost apunta al host)
#
# 3. Dar permisos al volumen de datos para el usuario del contenedor:
#    chmod 777 ~/.moorcheh/data/
#
# 4. Recrear el contenedor con los cambios:
#    moorcheh down && moorcheh up
#
# Verificar con: curl http://localhost:8080/health | grep items
# La causa raíz: Ollama escucha solo en 127.0.0.1, y el contenedor
# en bridge no puede alcanzarlo via host.docker.internal (Linux).
# ─────────────────────────────────────────────────────────────────────

# ── Constantes ──────────────────────────────────────────────────────

MOORCHEH_URL="http://localhost:8080"
MEMANTO_URL="http://localhost:8000"
MEMANTO_LOG="/tmp/memanto.log"
AGENT_ID="${MEMANTO_AGENT:-opencode}"

MEMANTO_PID=""

memanto_cleanup() {
    if [[ -n "$MEMANTO_PID" ]] && kill -0 "$MEMANTO_PID" 2> /dev/null; then
        kill "$MEMANTO_PID" 2> /dev/null || true
    fi
}
trap memanto_cleanup EXIT

# ── Helpers ─────────────────────────────────────────────────────────

memanto_health() {
    curl -sf "$1/health" -o /dev/null 2> /dev/null
}

memanto_start_moorcheh() {
    echo "  Moorcheh (backend vectorial)"
    while IFS= read -r line; do
        echo "   $line"
    done < <(moorcheh up 2>&1)
    if memanto_health "$MOORCHEH_URL"; then
        echo "     Moorcheh listo"
    else
        echo "  Moorcheh no responde, revisa docker"
        return 1
    fi
}

memanto_start() {
    echo "  MEMANTO REST API"
    if memanto_health "$MEMANTO_URL"; then
        echo "     MEMANTO ya estaba corriendo"
        return 0
    fi
    nohup memanto serve > "$MEMANTO_LOG" 2>&1 &
    MEMANTO_PID=$!
    # Esperar hasta 15s a que responda
    local retries=0
    while ! memanto_health "$MEMANTO_URL" && ((retries < 15)); do
        sleep 1
        ((retries++))
    done

    if ! memanto_health "$MEMANTO_URL"; then
        echo "  MEMANTO no arrancó, revisa $MEMANTO_LOG"
        return 1
    fi
    echo "     MEMANTO listo (PID $MEMANTO_PID)"
}

memanto_activate_agent() {
    echo "  Activando agente '$AGENT_ID'"
    local output
    output=$(memanto agent activate "$AGENT_ID" 2>&1) || {
        echo "  Error activando agente"
        return 1
    }
    if echo "$output" | grep -qi "already\|activado"; then
        echo "     Agente ya activo"
    else
        echo "     Agente activado"
    fi
}

# ── Orquestacion ────────────────────────────────────────────────────

echo -e "\n  Iniciando MEMANTO"

if ! memanto_health "$MOORCHEH_URL"; then
    memanto_start_moorcheh || exit 1
else
    echo "     Moorcheh ya disponible"
fi

memanto_start || exit 1
memanto_activate_agent

# Trap se desactiva: el proceso MEMANTO debe seguir corriendo tras la ejecución
MEMANTO_PID=""
echo -e "\n  MEMANTO operativo"
echo "    API:     $MEMANTO_URL"
echo "    Backend: $MOORCHEH_URL"
echo "    Agente:  $AGENT_ID"

# ── Verificar persistencia ─────────────────────────────────────────
# Si items es 0 el pipeline de embeddings falló (Ollama inalcanzable
# desde el contenedor). Ver sección "Fix: red host + permisos" arriba.
items=$(curl -sf "$MOORCHEH_URL/health" | python3 -c "
import json,sys
h = json.load(sys.stdin)
print(h.get('items', '?'))
" 2> /dev/null || echo "?")
if [[ "$items" == "0" ]]; then
    echo -e "\n  Items: $items — pipeline de embeddings no operativo"
elif [[ "$items" != "?" ]]; then
    echo -e "\n  Items: $items — persistencia funcional"
else
    echo -e "\n  No se pudo verificar items (health endpoint?)"
fi
