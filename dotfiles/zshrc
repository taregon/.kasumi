# в•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ
# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# POWERLEVEL10K INSTANT PROMPT
# Este bloque debe estar cerca del inicio de ~/.zshrc para
# que el prompt se cargue lo antes posible al abrir la terminal.
# NOTA: cualquier cГіdigo que requiera interacciГіn de usuario
# (passwords, confirmaciones [y/n], etc.) debe ir **antes** de este bloque.
#
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
    source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi
# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# ZINIT BOOTSTRAP
# ConfiguraciГіn inicial de Zinit: instala el gestor si no existe
# y lo deja listo para cargar plugins.
#
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
[ ! -d $ZINIT_HOME ] && mkdir -p "$(dirname $ZINIT_HOME)"
[ ! -d $ZINIT_HOME/.git ] && git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
source "${ZINIT_HOME}/zinit.zsh"

# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# AUTO COMPLETADO
# Carga compinit: usa cachГ© si tiene menos de 24h, sino lo crea
#
autoload -Uz compinit
ZCOMPDUMP="${ZDOTDIR:-$HOME}/.zcompdump"
if [[ -n $ZCOMPDUMP(Nmh-24) ]]; then
    compinit -C -d "$ZCOMPDUMP"
else
    compinit -d "$ZCOMPDUMP"
fi

# в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
#   ConfiguraciГіn de TERM para habilitar
#   pre visualizaciГіn de imГЎgenes en Ranger segГәn la terminal
# в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
# Se verifica si la sesiГіn actual corresponde a Kitty.
# La variable KITTY_WINDOW_ID es proporcionada automГЎticamente por Kitty
# y contiene un identificador Гәnico de la ventana.
# Se usa para que aplicaciones como ranger puedan determinar
# que el protocolo de imГЎgenes de Kitty puede ser empleado.
#
if [[ -n "$KITTY_WINDOW_ID" ]] && [[ -z "$TMUX" ]]; then
    # Se detecta Kitty mediante la variable KITTY_WINDOW_ID.
    # Se establece TERM=xterm-kitty para activar el protocolo grГЎfico nativo,
    # lo que permite a ranger mostrar previsualizaciones de imГЎgenes rГЎpidas y de alta calidad.
    # Este ajuste resulta la opciГіn recomendada y mГЎs fiable en entornos Kitty.
    export TERM="xterm-kitty"

    # Se define un alias para ssh que invoca el kitten oficial de Kitty (kitty +kitten ssh).
    # Beneficios principales:
    #   - Copia automГЎticamente el terminfo de Kitty al host remoto (solo en la primera conexiГіn),
    #     evitando errores de terminal desconocido o visualizaciones incorrectas.
    #   - Habilita la integraciГіn con el shell en el remoto (si resulta compatible: marcado de prompts,
    #     navegaciГіn entre prompts anteriores, etc.).
    #   - Reutiliza conexiones internas (multiplexing) para reducir la latencia en reconexiones.
    #   - Mejora la compatibilidad general: las caracterГӯsticas avanzadas de Kitty (incluido el
    #     protocolo grГЎfico) funcionan de manera mГЎs consistente en sesiones remotas.
    #   - Evita conflictos frecuentes que surgen al propagar TERM=xterm-kitty directamente mediante SSH convencional.
    alias ssh='kitty +kitten ssh'

else
    # En terminales distintas a Kitty (Alacritty, WezTerm, GNOME Terminal, etc.) o dentro de tmux
    # (donde el protocolo grГЎfico de Kitty suele fallar), se utiliza un TERM seguro
    # con soporte completo para 256 colores y alta compatibilidad general.
    export TERM="xterm-256color"
fi

